{
  "name": "priyoscript",
  "version": "1.6.0",
  "description": "An emotional, interpreted programming language.",
  "type": "commonjs",
  "preferGlobal": true,
  "engines": {
    "node": ">=18.0.0"
  },
  "bin": {
    "monalisa": "./bin/monalisa.js"
  },
  "files": [
    "bin/",
    "src/",
    "packages/",
    "SYNTAX.md",
    "ARCHITECTURE.md",
    "README.md",
    "LICENSE"
  ],
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js examples/basics/main.priyo",
    "run:examples": "node scripts/run-all.js",
    "build:exe:win": "pkg . --targets node18-win-x64 --output dist/priyoscript.exe",
    "build:exe:all": "pkg . --out-path dist",
    "dist:win": "powershell -ExecutionPolicy Bypass -File scripts/build-windows-exe.ps1",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "test": "vitest",
    "test:run": "vitest run",
    "release": "cliff-jumper"
  },
  "keywords": [
    "priyoscript",
    "complier",
    "emotions",
    "nodejs"
  ],
  "author": "nsgpriyanshu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nsgpriyanshu/PriyoScript"
  },
  "bugs": {
    "url": "https://github.com/nsgpriyanshu/PriyoScript/issues"
  },
  "homepage": "https://nsgpriyanshu.github.io/PriyoScript",
  "pkg": {
    "assets": [
      "src/**/*",
      "packages/**/*"
    ],
    "scripts": [
      "bin/**/*.js"
    ]
  },
  "devDependencies": {
    "@commitlint/config-angular": "^20.4.1",
    "@eslint/js": "^10.0.1",
    "@favware/cliff-jumper": "^6.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "pkg": "^5.8.1",
    "prettier": "3.8.1",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "nstypocolors": "^2.2.0"
  }
}
