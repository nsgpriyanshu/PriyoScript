{
  "name": "priyoscript",
  "version": "1.2.0",
  "description": "An emotional, interpreted programming language.",
  "type": "commonjs",
  "bin": {
    "monalisa": "./bin/monalisa.js"
  },
  "main": "src/index.js",
  "scripts": {
    "start": "node src/index.js  examples/main.priyo && node src/index.js examples/input.priyo && node src/index.js examples/declare.priyo",
    "format:check": "prettier . --check",
    "format:fix": "prettier . --write",
    "release": "cliff-jumper"
  },
  "keywords": [
    "priyoscript",
    "complier",
    "emotions",
    "nodejs"
  ],
  "author": "nsgpriyanshu",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/nsgpriyanshu/priyoscript"
  },
  "bugs": {
    "url": "https://github.com/nsgpriyanshu/priyoscript/issues"
  },
  "homepage": "https://nsgpriyanshu.github.io/priyoscript",
  "devDependencies": {
    "@commitlint/config-angular": "^20.4.1",
    "@eslint/js": "^10.0.1",
    "@favware/cliff-jumper": "^6.0.0",
    "eslint": "^10.0.0",
    "globals": "^17.3.0",
    "prettier": "3.8.1"
  },
  "dependencies": {
    "nstypocolors": "^2.2.0"
  }
}
