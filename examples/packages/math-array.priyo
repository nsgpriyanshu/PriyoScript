monalisa {
  priyoKeep math = priyoPackage.use("math")

  priyoTell("Cube: " + math.cube(2))
  priyoTell("Sqrt: " + math.sqrt(81))
  priyoTell("Pow: " + math.pow(2, 8))

  priyoKeep angle = math.degToRad(30)
  priyoTell("sin(30deg): " + math.sin(angle))
  priyoTell("cos(30deg): " + math.cos(angle))

  priyoTell("Area Circle r=5: " + math.areaCircle(5))
  priyoTell("Area Rectangle 10x20: " + math.areaRectangle(10, 20))
  priyoTell("Area Triangle 8x4: " + math.areaTriangle(8, 4))
}
