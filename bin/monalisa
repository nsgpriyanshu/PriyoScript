#!/usr/bin/env node
const path = require('path');
const runPriyoScript = require(path.join(__dirname, '../src/index'));

const filePath = process.argv[2];
if (!filePath) {
  console.error('Error: Please provide a .priyo file to run');
  process.exit(1);
}

runPriyoScript(path.resolve(process.cwd(), filePath));
